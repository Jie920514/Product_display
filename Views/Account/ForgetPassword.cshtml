@{
    ViewData["Title"] = "找回帳號密碼";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <h2 class="text-center mb-4">找回帳號密碼</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success">@ViewBag.Success</div>
                }

                <form asp-action="ForgetPassword" method="post">
                    <div class="mb-3">
                        <label class="form-label">電子信箱</label>
                        <input name="Email" type="email" class="form-control" placeholder="請輸入電子信箱" required />
                    </div>
                    <div class="d-flex gap-2">
                        <hr/>
                        <button type="submit" class="btn btn-primary w-100">確認發送</button>
                        <button type="button" class="btn btn-secondary w-25" onclick="history.back()">返回</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

