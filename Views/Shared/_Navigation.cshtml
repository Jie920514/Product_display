<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 商品展示系統</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/商品展示系統.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">商品展示系統</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">主頁</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="MyFavorite" asp-action="Index">我的最愛</a>
                        </li>
                        @if (Context.Session.GetInt32("Permissions") == 1)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Products" asp-action="Index">商品管理</a>
                            </li>
                        }
                    </ul>

                    @* --- 右側登入狀態區 --- *@
                    <ul class="navbar-nav">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">你好，@Context.Session.GetString("UserName")</span>
                            </li>

                            @* 只有非管理員(0) 才能看到修改資料 *@
                            @if (Context.Session.GetInt32("Permissions") == 0)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary" asp-controller="Account" asp-action="Modify">修改個人資料</a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">登出</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">登入</a>
                            </li>
                        }
                    </ul>

                    <form class="d-flex ms-lg-3" asp-controller="Home" asp-action="Index" method="get">
                        <input class="form-control me-2 border-0 shadow-sm"
                               type="search"
                               name="searchString"
                               placeholder="輸入品牌或型號..."
                               value="@Context.Request.Query["searchString"]">
                        <button class="btn btn-primary shadow-sm text-nowrap px-3" type="submit">搜尋</button>
                    </form>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - 商品展示系統 
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
